---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedBlogPosts } from '../utils/content';

// Fetch all posts and grab the latest 6 for the homepage grid
const allPosts = await getPublishedBlogPosts();
const recentPosts = allPosts.slice(0, 6);
---

<BaseLayout 
  title="Cloud Security Analysis | High-Performance Knowledge" 
  description="Enterprise-grade cybersecurity technical blog."
>
  <section class="py-16 md:py-24 text-center">
    <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4 text-slate-50">
      Master <span class="text-emerald-400">Cloud Security</span>
    </h1>
    <p class="text-lg text-slate-400 max-w-2xl mx-auto mb-8">
      Authoritative insights, technical breakdowns, and enterprise-grade strategies for modern cybersecurity professionals.
    </p>
    <a href="/blog" class="inline-block bg-emerald-500 hover:bg-emerald-400 text-slate-900 font-bold py-3 px-8 rounded-md transition-colors">
      Read Latest Articles
    </a>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-bold text-slate-100 mb-6 border-b border-slate-800 pb-2">Recent Technical Analysis</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {recentPosts.map(post => (
        <article class="bg-slate-800/40 rounded-lg p-6 border border-slate-700 hover:border-emerald-500/50 transition-colors flex flex-col h-full">
          <span class="text-xs font-semibold text-emerald-400 uppercase tracking-wider mb-2">
            {post.data.category}
          </span>
          <h3 class="text-xl font-bold text-slate-100 mb-3 leading-snug">
            <a href={`/blog/${post.id}`} class="hover:text-emerald-300 transition-colors">
              {post.data.title}
            </a>
          </h3>
          <p class="text-slate-400 text-sm line-clamp-3 mb-4 flex-grow">
            {post.data.description}
          </p>
          <div class="text-xs text-slate-500 mt-auto">
            {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })} 
            &bull; By {post.data.author}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>