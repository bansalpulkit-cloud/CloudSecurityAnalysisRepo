---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchComponent from '../components/Search.astro';
---

<BaseLayout 
  title="Search | Cloud Security Analysis" 
  description="Search across our entire database of enterprise-grade cybersecurity articles."
>
  <div class="search-header">
    <h1 class="page-title">Search Articles</h1>
    <p class="page-description">Find technical breakdowns, configurations, and security analyses.</p>
  </div>

  <SearchComponent />
  
</BaseLayout>

<style>
  .search-header {
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--color-bg-border);
    padding-bottom: 1.5rem;
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }

  .page-description {
    color: var(--color-text-muted);
    font-size: 1.125rem;
  }
</style>