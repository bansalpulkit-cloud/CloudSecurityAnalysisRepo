---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { Image } from 'astro:assets';


// 1. Tell Astro which URLs to generate at build time based on your Markdown files
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => {
    return data.isDraft !== true;
  });
  
  return posts.map(post => ({
    // Using post.id to align with the modern Astro Glob Loader
    params: { slug: post.id }, 
    props: { post },
  }));
}

// 2. Extract the data and the render function for the current post
const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout 
  title={`${post.data.title} | Cloud Security Analysis`} 
  description={post.data.description}
  image={post.data.featuredImage} 
  articleDate={post.data.pubDate.toISOString()}
>
   <article class="article-container">
    <Breadcrumbs />
<header class="article-header">
      <span class="category-badge">{post.data.category}</span>
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-meta">
        By <span class="author-name">{post.data.author}</span> &bull; 
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </time>
      </p>
      
      {post.data.featuredImage && (
        <div class="mt-8 rounded-xl overflow-hidden border border-slate-700">
          <Image 
            src={post.data.featuredImage} 
            alt={post.data.title}
            width={800}
            height={450}
            format="webp"
            class="w-full h-auto object-cover"
          />
        </div>
      )}
    </header>

    <div class="article-content" data-pagefind-body>
      <Content />
    </div>

    <footer class="article-footer">
      <div class="tags-list">
        {post.data.tags.map(tag => (
          <span class="tag">#{tag}</span>
        ))}
      </div>
    </footer>
  </article>


  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.description,
    "image": [new URL(post.data.featuredImage || '/default-social-card.png', Astro.site).toString()],
    "datePublished": post.data.pubDate.toISOString(),
    "dateModified": post.data.updatedDate ? post.data.updatedDate.toISOString() : post.data.pubDate.toISOString(),
    "author": [{
      "@type": "Person",
      "name": post.data.author,
      "url": new URL("/about", Astro.site).toString()
    }]
  })} />

</BaseLayout>

<style>
  /* --- Layout & Header --- */
  .article-container {
    max-width: 720px; /* Slightly narrower for optimal reading line-length */
    margin: 0 auto;
    padding: 2rem 0;
  }

  .article-header {
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--color-bg-border);
    padding-bottom: 2rem;
  }

  .category-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .article-title {
    font-size: 2.5rem;
    line-height: 1.2;
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }

  .article-meta {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .author-name {
    color: var(--color-text-primary);
    font-weight: 500;
  }

  /* --- Markdown Content Styling --- */
  .article-content {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--color-text-primary);
  }

  /* Target headers generated by Markdown */
  .article-content h2 {
    font-size: 1.875rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }

  .article-content h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  /* Target paragraphs and lists */
  .article-content p {
    margin-bottom: 1.5rem;
  }

  .article-content ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .article-content li {
    margin-bottom: 0.5rem;
  }

  /* Target links */
  .article-content a {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color 0.2s ease;
  }

  .article-content a:hover {
    text-decoration-color: var(--color-accent);
  }

  /* Target code elements (applying your monospace font rule) */
  .article-content code {
    font-family: var(--font-mono);
    background-color: var(--color-bg-secondary);
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
  }

  .article-content pre {
    background-color: var(--color-bg-secondary);
    padding: 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    border: 1px solid var(--color-bg-border);
  }

  .article-content pre code {
    background-color: transparent;
    padding: 0;
  }

  /* --- Footer & Tags --- */
  .article-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-bg-border);
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tag {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    background-color: var(--color-bg-secondary);
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
  }
</style>