---
<div class="search-wrapper">
  <div id="search"></div>
</div>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" is:inline />
<script src="/pagefind/pagefind-ui.js" is:inline></script>

<script is:inline>
  window.addEventListener('DOMContentLoaded', (event) => {
    new PagefindUI({ 
      element: "#search", 
      showSubResults: true,
      // Customize the default Pagefind UI to match our Dark Mode aesthetic
      resetStyles: false 
    });
  });
</script>

<style is:global>
  /* Scoping global overrides specifically for the Pagefind injected elements */
  .search-wrapper {
    width: 100%;
    margin: 2rem 0;
  }
  
  :root {
    --pagefind-ui-primary: var(--color-accent);
    --pagefind-ui-text: var(--color-text-primary);
    --pagefind-ui-background: var(--color-bg-secondary);
    --pagefind-ui-border: var(--color-bg-border);
    --pagefind-ui-tag: var(--color-bg-primary);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: var(--font-system);
  }

.pagefind-ui__search-input {
    background-color: var(--color-bg-secondary) !important;
    color: var(--color-text-primary) !important;
    border: 1px solid var(--color-bg-border) !important;
    font-weight: 400 !important;
  }
  
  /* Let's also ensure the "Clear" button looks good on the dark background */
  .pagefind-ui__search-clear {
    background-color: transparent !important;
    color: var(--color-text-muted) !important;
  }
  
  .pagefind-ui__result-excerpt {
    color: var(--color-text-muted) !important;
  }
</style>