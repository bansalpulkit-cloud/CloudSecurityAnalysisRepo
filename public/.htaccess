<IfModule mod_headers.c>
    # --- SECURITY HEADERS (Week 23) ---
    
    # 1. Content Security Policy (CSP)
    # Restricts where resources can be loaded from. 
    # (Allows 'self' and inline scripts/styles which Astro uses for scoped CSS and Pagefind)
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self';"

    # 2. Prevent Clickjacking (Ensures your site cannot be embedded in a malicious iframe)
    Header always set X-Frame-Options "SAMEORIGIN"

    # 3. Prevent MIME-type Sniffing
    Header always set X-Content-Type-Options "nosniff"

    # 4. Referrer Policy (Protects user privacy when they click outbound links)
    Header always set Referrer-Policy "strict-origin-when-cross-origin"


    # --- CACHING RULES (Week 20) ---
    <FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|webp|avif|js|css|swf|svg|woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "public, max-age=0, must-revalidate"
    </FilesMatch>

    <FilesMatch "\.(xml)$">
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>
</IfModule>
<IfModule mod_headers.c>
    # 1. Aggressive Caching for Static Assets (Images, CSS, JS, Fonts)
    # Astro automatically hashes these filenames (e.g., style.8f3b2.css), 
    # so it is completely safe to cache them in the browser/Cloudflare for 1 year.
    <FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|webp|avif|js|css|swf|svg|woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # 2. No-Cache for HTML Files
    # We want browsers to always check with Cloudflare for a newer version of your HTML,
    # ensuring readers instantly see new articles or typo fixes when you publish.
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "public, max-age=0, must-revalidate"
    </FilesMatch>

    # 3. RSS and XML caching (Sitemaps)
    # Cache for 1 hour to balance performance and freshness
    <FilesMatch "\.(xml)$">
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>
</IfModule>